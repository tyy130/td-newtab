{
  "manifest_version": 3,
  "name": "TacticDev Tab - developer news",
  "description": "All developer news in one tab",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "host_permissions": [
    "https://*.tacticdev.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tacticdev.com/*"
      ],
      "run_at": "document_start",
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "/logos/logo16.png",
    "32": "/logos/logo32.png",
    "48": "/logos/logo48.png",
    "128": "/logos/logo128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {}
}
